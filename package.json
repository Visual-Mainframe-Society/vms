{
  "name": "vms",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-s clean generate-pwa type-check build-only",
    "build-only": "vite build",
    "postbuild": "node -e \"require('fs').writeFileSync('dist/.nojekyll', '')\"",
    "preview": "vite preview",
    "type-check": "vue-tsc --build",
    "clean": "node -e \"if (require('fs').existsSync('dist')) require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "generate-pwa": "pwa-assets-generator",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "deploy": "gh-pages -d dist --dotfiles",
    "ship-it": "run-s build deploy"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "beta",
    "vue-advanced-cropper": "^2.8.9",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "gh-pages": "^6.3.0",
    "install": "^0.13.0",
    "jiti": "^2.6.1",
    "npm": "^11.12.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "~1.57.0",
    "pinia-plugin-persistedstate": "^4.7.1",
    "sass-embedded": "^1.99.0",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "@vue/compat": "beta",
    "@vue/compiler-core": "beta",
    "@vue/compiler-dom": "beta",
    "@vue/compiler-sfc": "beta",
    "@vue/compiler-ssr": "beta",
    "@vue/compiler-vapor": "beta",
    "@vue/reactivity": "beta",
    "@vue/runtime-core": "beta",
    "@vue/runtime-dom": "beta",
    "@vue/runtime-vapor": "beta",
    "@vue/server-renderer": "beta",
    "@vue/shared": "beta",
    "vue": "beta"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
